    "lint": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsx": "^4.19.0"
  }
}
