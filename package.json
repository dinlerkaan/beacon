{
  "name": "beacon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "build": "pnpm -r --filter ./packages/* build",
